{
  "_README": "Canonical Emerge Digital design tokens — the single source of truth for the 3-site ecosystem (vision/future/roai) AND for Hyperframes video. Extracted verbatim from emerge-digital-website (tailwind.config.mjs + src/styles/global.css), the most complete token set. Each site re-declares these in its own stack; this file is what they must match. Companion: design.md (rules), frame.md (video translation). Sibling canonical-facts.json holds product/proof facts (not design).",
  "version": "1.0.0",
  "as_of": "2026-06-17",
  "source_of_truth": "emerge-digital-website/tailwind.config.mjs + src/styles/global.css",

  "color": {
    "navy": { "DEFAULT": "#0A1F3D", "950": "#04091A", "900": "#06122A", "800": "#0A1F3D", "700": "#152A4D", "600": "#1F3760", "500": "#2A4A7F" },
    "ink": { "DEFAULT": "#06122A", "deep": "#03081A", "surface": "#040D1F" },
    "teal": { "DEFAULT": "#00C2C7", "50": "#E6FAFB", "100": "#C0F3F5", "200": "#7EEEF0", "300": "#3DDCE3", "400": "#1ACFCE", "500": "#00C2C7", "600": "#00A8AD", "700": "#008A8E", "glow": "#00F5FF" },
    "cyan": { "DEFAULT": "#3DDCE3", "bright": "#00F5FF" },
    "platinum": { "DEFAULT": "#E8EEF5", "50": "#F7F9FC" },
    "offwhite": "#F7F9FC",
    "slate": { "DEFAULT": "#1F2A3C", "900": "#1F2A3C", "800": "#2A3650", "700": "#374563" },
    "cool": { "DEFAULT": "#7E8CA3", "400": "#8596AB", "300": "#9FAFC2" },
    "semantic": { "success": "#3FCF8E", "warning": "#FFB547", "danger": "#E5484D" }
  },

  "roles": {
    "surface_dark": "navy.DEFAULT (#0A1F3D)",
    "surface_deepest": "ink.DEFAULT (#06122A) / ink.deep (#03081A) for hero base",
    "accent": "teal.DEFAULT (#00C2C7) — primary accent + CTA, ALL surfaces incl. the roai product UI",
    "accent_hover": "teal.600 (#00A8AD)",
    "accent_secondary": "cyan.DEFAULT (#3DDCE3) — hover / secondary highlight",
    "accent_glow": "teal.glow (#00F5FF)",
    "surface_light": "platinum.DEFAULT (#E8EEF5) / offwhite (#F7F9FC)",
    "text_on_light": "slate.DEFAULT (#1F2A3C)",
    "text_muted": "cool.DEFAULT (#7E8CA3)",
    "cta_rule": "navy text on teal/gold buttons — NEVER white-on-teal for the primary CTA label; use navy ink for contrast."
  },

  "gradients": {
    "accent": "linear-gradient(90deg, #00C2C7 0%, #3DDCE3 100%)",
    "accent-diagonal": "linear-gradient(135deg, #00C2C7 0%, #3DDCE3 100%)",
    "accent-vertical": "linear-gradient(180deg, #3DDCE3 0%, #00C2C7 100%)",
    "accent-glow": "linear-gradient(90deg, #00C2C7 0%, #3DDCE3 50%, #00F5FF 100%)",
    "hero": "radial-gradient(ellipse 90% 70% at 80% 0%, rgba(0,194,199,0.18), transparent 60%), radial-gradient(ellipse 70% 60% at 10% 90%, rgba(61,220,227,0.10), transparent 65%), linear-gradient(160deg, #06122A 0%, #0A1F3D 55%, #06122A 100%)",
    "data": "linear-gradient(180deg, #0A1F3D 0%, #00C2C7 100%)",
    "navy": "linear-gradient(180deg, #0A1F3D 0%, #06122A 100%)",
    "ink": "linear-gradient(180deg, #06122A 0%, #03081A 100%)",
    "border-teal": "linear-gradient(135deg, rgba(0,194,199,0.7) 0%, rgba(61,220,227,0.2) 40%, rgba(0,194,199,0.05) 70%, rgba(61,220,227,0.35) 100%)"
  },

  "typography": {
    "families": {
      "sans": ["Lexend Variable", "Lexend", "system-ui", "sans-serif"],
      "display": ["Lexend Variable", "Lexend", "system-ui", "sans-serif"],
      "wide": ["Lexend Zetta", "Lexend Variable", "system-ui", "sans-serif"],
      "label": ["Prompt", "Lexend Variable", "system-ui", "sans-serif"],
      "mono": ["JetBrains Mono Variable", "ui-monospace", "monospace"]
    },
    "loading": {
      "vision": "@fontsource (npm, self-hosted)",
      "future_and_roai": "Google Fonts <link>",
      "note": "roai currently uses Geist Mono; canonical mono is JetBrains Mono (open decision — see design.md)."
    },
    "scale": {
      "display-2xl": { "size": "clamp(3.5rem, 8.5vw, 6.75rem)", "lineHeight": "0.95", "letterSpacing": "-0.035em", "fontWeight": "700" },
      "display-xl": { "size": "clamp(2.75rem, 6vw, 4.75rem)", "lineHeight": "1.02", "letterSpacing": "-0.03em", "fontWeight": "700" },
      "display-lg": { "size": "clamp(2rem, 4vw, 3.25rem)", "lineHeight": "1.08", "letterSpacing": "-0.025em", "fontWeight": "700" },
      "display-md": { "size": "clamp(1.5rem, 2.4vw, 2.125rem)", "lineHeight": "1.18", "letterSpacing": "-0.018em", "fontWeight": "600" },
      "display-sm": { "size": "clamp(1.15rem, 1.6vw, 1.45rem)", "lineHeight": "1.3", "letterSpacing": "-0.012em", "fontWeight": "600" },
      "lead": { "size": "1.2rem", "lineHeight": "1.65", "fontWeight": "400" },
      "lead-sm": { "size": "1.05rem", "lineHeight": "1.6", "fontWeight": "400" },
      "eyebrow": { "size": "0.75rem", "lineHeight": "1.4", "letterSpacing": "0.18em", "fontWeight": "600" }
    },
    "letterSpacing": { "eyebrow": "0.18em", "tightest": "-0.04em", "wide": "0.08em" }
  },

  "radii": { "card": "1.25rem", "card-lg": "1.75rem", "pill": "9999px", "xl": "1rem", "2xl": "1.25rem", "3xl": "1.75rem" },

  "shadow": {
    "glow": "0 0 0 1px rgba(0,194,199,0.4), 0 8px 32px rgba(0,194,199,0.18)",
    "glow-lg": "0 0 0 1px rgba(0,194,199,0.5), 0 24px 80px rgba(0,194,199,0.32)",
    "glow-xl": "0 0 60px rgba(0,194,199,0.3), 0 0 120px rgba(0,194,199,0.15)",
    "elevated": "0 30px 80px -30px rgba(0,194,199,0.18), 0 20px 60px -20px rgba(6,18,42,0.55)",
    "ring": "0 0 0 1px rgba(255,255,255,0.06)",
    "ring-teal": "0 0 0 1px rgba(0,194,199,0.25)",
    "card-hover": "0 0 0 1px rgba(0,194,199,0.35), 0 20px 60px rgba(0,194,199,0.14), 0 40px 80px rgba(3,8,26,0.5)"
  },

  "layout": {
    "grid_base": "8px",
    "maxWidth": { "prose": "72ch", "section": "80rem", "wide": "90rem" },
    "spacing": { "section": "8rem", "section-sm": "4rem", "section-lg": "12rem" }
  },

  "motion": {
    "easing": {
      "out-expo": "cubic-bezier(0.16, 1, 0.3, 1)",
      "out-quint": "cubic-bezier(0.22, 1, 0.36, 1)",
      "out-back": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "in-out-quart": "cubic-bezier(0.76, 0, 0.24, 1)",
      "spring": "cubic-bezier(0.43, 0.195, 0.02, 1)"
    },
    "signature_keyframes": {
      "fade-up": "opacity 0→1, translateY(22px→0)",
      "fade-in": "opacity 0→1",
      "scale-in": "opacity 0→1, scale(0.94→1)",
      "glow-pulse": "opacity 0.5↔1 (3s loop)",
      "shimmer": "backgroundPosition -200%→200% (sheen sweep)",
      "beam-sweep": "translateX(-120%→120%) skewX(-10deg) (light beam)",
      "data-flow": "strokeDashoffset 200→0 (line draw)",
      "counter-in": "opacity 0→1, translateY(8px→0) (number reveal)"
    },
    "default_entrance": "fade-up 0.9s out-expo",
    "default_scale": "scale-in 0.6s out-expo",
    "reveal_cascade_ms": [80, 160, 240, 320, 400]
  }
}
